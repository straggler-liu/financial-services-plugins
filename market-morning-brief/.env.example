# ════════════════════════════════════════════════════════════════════
#  市场晨报系统 - 环境变量配置
#  复制此文件为 .env 并填写真实值
#  cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ── 强烈推荐：Anthropic API Key（Claude 大模型分析）─────────────────
# 申请地址：https://console.anthropic.com/
# 配置后将使用 Claude 进行深度语义分析（市场摘要、传导链条、操作建议、收盘复盘质量大幅提升）
# 未配置时自动降级为规则引擎（关键词匹配，分析质量较低）
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude 模型版本（可选，默认使用 claude-sonnet-4-6）
# CLAUDE_MODEL=claude-sonnet-4-6

# ── 必填：飞书 Webhook ────────────────────────────────────────────────
# 接入说明：https://open.feishu.cn/document/client-docs/bot-v3/add-custom-bot
# 支持多个 Webhook，逗号分隔（可推送到多个群）
FEISHU_WEBHOOK_URLS=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# 飞书机器人签名密钥（可选，提升安全性）
# FEISHU_SECRET=your_feishu_secret_here

# ── 可选：增强数据源 ──────────────────────────────────────────────────
# Alpha Vantage（免费，每天 25 次请求）
# 申请地址：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=demo

# NewsAPI（免费，每天 100 次请求）
# 申请地址：https://newsapi.org/register
# NEWSAPI_KEY=your_newsapi_key_here

# ── 可选：代理（如需翻墙访问境外数据源）─────────────────────────────
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ── 调度时间配置（CST, UTC+8）────────────────────────────────────────
# A股+港股 开盘前分析（默认 09:00，即开盘前30分钟）
ASIA_PREMARKET_HOUR=9
ASIA_PREMARKET_MINUTE=0

# A股+港股 收盘复盘（默认 15:30，即收盘后30分钟）
ASIA_POSTMARKET_HOUR=15
ASIA_POSTMARKET_MINUTE=30

# 美股 开盘前分析（默认 21:00 CST）
# 注：美国夏令时（3月第2周~11月第1周）开盘时间为 21:30 CST
#     美国冬令时开盘时间为 22:30 CST，建议设为 22:00
US_PREMARKET_HOUR=21
US_PREMARKET_MINUTE=0

# ── 关注配置 ─────────────────────────────────────────────────────────
# 重点关注板块（逗号分隔）
FOCUS_SECTORS=科技,新能源,半导体,消费,医药,金融,房地产,人工智能,军工

# 自选标的（逗号分隔，支持A股代码/港股代码/美股Ticker）
# 示例：WATCHLIST=600519,00700,AAPL,NVDA,BABA
WATCHLIST=

# ── 运行模式 ─────────────────────────────────────────────────────────
# scheduler = 定时模式（生产用）| manual = 手动模式（调试用）
RUN_MODE=scheduler

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 数据缓存目录（策略记忆、日志存储）
# Windows 本地运行时可留空（自动使用项目目录下的 cache 文件夹）
# Docker 部署时固定为 /app/cache
# CACHE_DIR=cache
